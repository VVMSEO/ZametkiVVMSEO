rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The user ID of the note owner
    //   - title: string (required) - The title of the note
    //   - content: string (required) - The rich text content of the note (max 50000 chars)
    //   - plainText: string (required) - The plain text snippet of the note (max 200 chars)
    //   - isPinned: boolean (required) - Whether the note is pinned
    //   - createdAt: number (required, immutable) - Timestamp of creation
    //   - updatedAt: number (required) - Timestamp of last update
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidNote(data) {
      return data.uid is string &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.plainText is string && data.plainText.size() <= 200 &&
             data.isPinned is bool &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      
      allow create: if isAuthenticated() && 
                       hasRequiredFields(['uid', 'title', 'content', 'plainText', 'isPinned', 'createdAt', 'updatedAt']) &&
                       isValidNote(request.resource.data) && 
                       request.resource.data.uid == request.auth.uid;
                       
      allow update: if isDocOwner() && 
                       isValidNote(request.resource.data) &&
                       uidNotModified() &&
                       areImmutableFieldsUnchanged(['createdAt']);
                       
      allow delete: if isDocOwner();
    }
  }
}
